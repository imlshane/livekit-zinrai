# Auth service
SECRET_KEY=change-this-to-a-random-hex-secret

# VOD upload — S3-compatible (Cloudflare R2 or DO Spaces)
# Leave blank to skip upload and keep .mp4 locally
S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com
S3_BUCKET=streams
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Recordings platform — stream events are pushed here in real-time
RECORD_URL=https://your-recordings-platform.com
RECORD_API_KEY=sk-your-api-key-here

# Production server (not needed for local testing)
SERVER_IP=YOUR_SERVER_PUBLIC_IP
DOMAIN=your.domain.com
