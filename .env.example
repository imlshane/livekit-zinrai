# Auth service
SECRET_KEY=change-this-to-a-random-hex-secret

# VOD upload — S3-compatible (Cloudflare R2 or DO Spaces)
# Leave blank to skip upload and keep .mp4 locally
S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com
S3_BUCKET=streams
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Redis — stream analytics (leave as default for local Docker; use managed URL for production)
REDIS_URL=redis://redis:6379

# Management API key — protects /publishers, /token, /streams, /stats endpoints
# Generate with: openssl rand -hex 32
MANAGEMENT_API_KEY=

# Recordings platform — stream events are pushed here in real-time
RECORD_URL=https://your-recordings-platform.com
RECORD_API_KEY=sk-your-api-key-here

# Server public IP — used as WebRTC ICE candidate so browsers can reach the media server
# Required for WebRTC playback to work; set to the host machine's public IPv4 address
SERVER_IP=YOUR_SERVER_PUBLIC_IP

# Domain and SSL — Caddy uses these to obtain and renew TLS certs automatically
# DNS A record for DOMAIN must already point to SERVER_IP before starting
DOMAIN=devlivestream.zinrai.live
ACME_EMAIL=your-email@example.com
