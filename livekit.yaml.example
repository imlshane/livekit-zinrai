port: 7880
bind_addresses:
  - 127.0.0.1

rtc:
  tcp_port: 7881
  port_range_start: 50000
  port_range_end: 51000
  use_external_ip: true
  node_ip: YOUR_SERVER_PUBLIC_IP

keys:
  YOUR_API_KEY: YOUR_API_SECRET

# --- Option A: DO Managed Redis (recommended) ---
redis:
  address: YOUR_DO_REDIS_HOST:25061
  password: YOUR_DO_REDIS_PASSWORD
  use_tls: true

# --- Option B: Local Redis container ---
# redis:
#   address: 127.0.0.1:6379

logging:
  level: info

room:
  empty_timeout: 300
  departure_timeout: 20
